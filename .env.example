# Copy to .env and fill in. Never commit .env.

# --- Required for run_demo.py ---
# Absolute path to a locally built llama.cpp llama-server binary.
LLAMA_SERVER_BIN=

# --- DriveAuth Edge (payment Trust/Risk); mock defaults for demos ---
DRIVEAUTH_USE_MOCK=1
DRIVEAUTH_SEED_MATURE=1
DRIVEAUTH_STORE_DIR=runtime/driveauth_store
DRIVEAUTH_DRIVER_ID=driver1
# DRIVEAUTH_ENROLL_DIR=
# DRIVEAUTH_DRIVER_MOBILE=

# --- Optional tool keys (missing → tool returns unavailable) ---
# TAVILY_API_KEY=
# BRAVE_API_KEY=
# SERPER_API_KEY=

# --- Google Workspace OAuth (calendar / gmail / drive) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/oauth/callback
# GOOGLE_OAUTH_TOKEN_PATH=runtime/google_oauth/tokens.json
